          <datasource-dependencies datasource='federated.1vp6o5f0gsd80j13vxttm18eewn9'>
            <column caption='% Differrence' datatype='real' name='[Calculation_0048854129860609]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([Calculation_0071806082838548])-SUM([YTD Sales (copy)_0048854129692672]))/SUM([YTD Sales (copy)_0048854129692672])' />
            </column>
            <column caption='Sales Margin' datatype='string' name='[Calculation_0048854130458626]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF SUM([Calculation_0071806082838548])- SUM([YTD Sales (copy)_0048854129692672])&lt;0 THEN &apos;Less than PY&apos;&#10;ELSEIF SUM([Calculation_0071806082838548])- SUM([YTD Sales (copy)_0048854129692672])&gt;0 THEN&apos;Greater than PY&apos;&#10;ELSEIF ISNULL (SUM([YTD Sales (copy)_0048854129692672]))THEN &apos;No Sales in PY&apos;&#10;END' />
            </column>
            <column caption='YTD Sales' datatype='real' name='[Calculation_0071806082838548]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date])= {MAX(YEAR([Order Date]))} THEN [Sales] END' />
            </column>
            <column datatype='string' name='[Category Name]' role='dimension' type='nominal' />
            <column datatype='date' name='[Order Date]' role='dimension' type='ordinal' />
            <column datatype='real' name='[Sales]' role='measure' type='quantitative' />
            <column caption='PYTD Sales' datatype='real' name='[YTD Sales (copy)_0048854129692672]' role='measure' type='quantitative'>
